# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
# .env is gitignored — never commit real credentials
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS ───────────────────────────────────────────────────────────────────────
# On EC2 with an IAM instance role, leave these blank — credentials are
# provided automatically via the instance metadata service.
# Fill in only if running locally with explicit access keys.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2

# ── S3 ────────────────────────────────────────────────────────────────────────
# Bucket and prefix where Iceberg data and metadata will be stored.
# The IRC warehouse points to s3://${S3_BUCKET}/${S3_PREFIX}/
S3_BUCKET=mhoerth-gravitino-benchmark

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=gravitino_root
MYSQL_DATABASE=iceberg_catalog
MYSQL_USER=iceberg
MYSQL_PASSWORD=iceberg_password

# ── Gravitino IRC ─────────────────────────────────────────────────────────────
IRC_PORT=9001
IRC_MEM=-Xms512m -Xmx2g -XX:MaxMetaspaceSize=256m

# ── Trino ─────────────────────────────────────────────────────────────────────
TRINO_PORT=8080
