FROM apache/gravitino-iceberg-rest:1.2.0

ADD https://repo1.maven.org/maven2/org/postgresql/postgresql/42.7.3/postgresql-42.7.3.jar \
    /root/gravitino-iceberg-rest-server/libs/postgresql-42.7.3.jar

ADD https://repo1.maven.org/maven2/org/apache/iceberg/iceberg-aws-bundle/1.6.1/iceberg-aws-bundle-1.6.1.jar \
    /root/gravitino-iceberg-rest-server/libs/iceberg-aws-bundle-1.6.1.jar

RUN chmod 644 /root/gravitino-iceberg-rest-server/libs/postgresql-42.7.3.jar \
              /root/gravitino-iceberg-rest-server/libs/iceberg-aws-bundle-1.6.1.jar

RUN sed -i 's|python bin/rewrite_config.py|python bin/rewrite_config.py \&\& echo "gravitino.iceberg-rest.s3-secret-key.s3.access-key-id = $GRAVITINO_S3_ACCESS_KEY" >> conf/gravitino-iceberg-rest-server.conf \&\& echo "gravitino.iceberg-rest.s3-secret-key.s3.secret-access-key = $GRAVITINO_S3_SECRET_KEY" >> conf/gravitino-iceberg-rest-server.conf \&\& echo "gravitino.iceberg-rest.s3-secret-key.s3.region = $GRAVITINO_S3_REGION" >> conf/gravitino-iceberg-rest-server.conf|' bin/start-iceberg-rest-server.sh
